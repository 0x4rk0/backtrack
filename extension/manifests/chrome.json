{
  "manifest_version": 3,
  "name": "backtrack",
  "version": "0.1.0",
  "description": "Capture visited page text and screenshots into the local backtrack server.",
  "permissions": [
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "http://127.0.0.1:4317/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "exclude_matches": [
        "http://127.0.0.1/*",
        "http://localhost/*",
        "http://[::1]/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
