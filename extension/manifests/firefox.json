{
  "manifest_version": 2,
  "name": "backtrack",
  "version": "0.1.0",
  "description": "Capture visited page text and screenshots into the local backtrack server.",
  "permissions": [
    "tabs",
    "activeTab",
    "http://127.0.0.1:4317/*",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "backtrack@local"
    }
  }
}
